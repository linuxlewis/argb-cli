{
  "name": "argb-cli",
  "version": "0.1.0",
  "description": "Agent-first TypeScript CLI and harness for interacting with ARGB devices.",
  "type": "module",
  "bin": {
    "argb": "./dist/cli.js"
  },
  "files": [
    "dist",
    "harness",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
